{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noUncheckedIndexedAccess": false,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.vitest.tsbuildinfo",
    "checkJs": true,
    "types": ["vitest/globals", "node", "vite/client"],
    "paths": {
      "gps-plus-slam-app-framework": [
        "../GpsPlusSlamJs_AppFramework/src/index.ts"
      ],
      "gps-plus-slam-app-framework/*": ["../GpsPlusSlamJs_AppFramework/src/*"]
    }
  },
  "exclude": [
    "dist",
    "coverage",
    "node_modules",
    "../GpsPlusSlamJs_AppFramework/src/**/*.test.ts",
    "../GpsPlusSlamJs_AppFramework/src/**/*.spec.ts"
  ]
}
